# Copy this file to .env and adjust paths for your DGX Spark host.

# Dedicated custom vLLM image from https://github.com/0xSero/deepseek-spark.
DEEPSEEK_SPARK_IMAGE=ghcr.io/0xsero/deepseek-v4-flash-spark-vllm:cutlass451-g27

# Existing Hugging Face cache root. The stack expects the model snapshots to be
# present here, or mounted by an equivalent path from your host.
DEEPSEEK_SPARK_HF_HOME=/home/YOUR_USER/LLMs/hf-cache
HF_TOKEN=

# K160 / 180B default profile.
DEEPSEEK_SPARK_PORT=8003
DEEPSEEK_SPARK_MODEL_REPO=0xSero/DeepSeek-V4-Flash-180B
DEEPSEEK_SPARK_MODEL_REVISION=7c360e1cd4a5168099dbc54d16d929bf6df04990
DEEPSEEK_SPARK_MODEL_DIR=
DEEPSEEK_SPARK_SERVED_MODEL_NAME=DeepSeek-V4-Flash-Spark
DEEPSEEK_SPARK_CONTEXT_LENGTH=200000
DEEPSEEK_SPARK_KV_CACHE_MEMORY_BYTES=6G
DEEPSEEK_SPARK_KV_CACHE_DTYPE=fp8
DEEPSEEK_SPARK_MAX_NUM_BATCHED_TOKENS=4096
DEEPSEEK_SPARK_MAX_NUM_SEQS=1
DEEPSEEK_SPARK_GPU_MEMORY_UTILIZATION=0.88
DEEPSEEK_SPARK_THINKING=true
DEEPSEEK_SPARK_SPECULATIVE_CONFIG={"method":"deepseek_mtp","num_speculative_tokens":2}
DEEPSEEK_SPARK_ENFORCE_EAGER=0

# Optional K144 / 162B Mini profile. Start with: docker compose --profile mini up -d
DEEPSEEK_SPARK_MINI_PORT=8004
DEEPSEEK_SPARK_MINI_MODEL_REPO=0xSero/DeepSeek-V4-Flash-162B
DEEPSEEK_SPARK_MINI_MODEL_REVISION=d663e8fb16809f6619000648b187b257249ed824
DEEPSEEK_SPARK_MINI_MODEL_DIR=
DEEPSEEK_SPARK_MINI_SERVED_MODEL_NAME=DeepSeek-V4-Flash-Spark-Mini
DEEPSEEK_SPARK_MINI_CONTEXT_LENGTH=200000
DEEPSEEK_SPARK_MINI_KV_CACHE_MEMORY_BYTES=14G
DEEPSEEK_SPARK_MINI_MAX_NUM_BATCHED_TOKENS=8192
DEEPSEEK_SPARK_MINI_MAX_NUM_SEQS=1
DEEPSEEK_SPARK_MINI_GPU_MEMORY_UTILIZATION=0.88

# Shared Docker network created by Docker/VLLM-LiteLLM.
LITELLM_NETWORK=vllm-litellm_llmnet
