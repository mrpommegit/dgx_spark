# Copy this file to .env and adjust values for your server.

# Folder on the host that already contains your downloaded Hugging Face models.
# Example: /home/your-user/LLMs
LLM_DIR=/home/YOUR_USER/LLMs

# Ports exposed on the host.
MANAGER_PORT=8088
LITELLM_PORT=4000
OPEN_WEBUI_PORT=3000

# vLLM runtime defaults. These can also be changed from the Manager UI.
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_NUM_SEQS=16
VLLM_DTYPE=auto
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_QUANTIZATION=
VLLM_EXTRA_ARGS=

# Dedicated AEON vLLM runtime. Uses the patched AEON image and DFlash drafter.
AEON_VLLM_IMAGE=ghcr.io/aeon-7/aeon-vllm-ultimate:latest
AEON_MODEL_REPO=AEON-7/Qwen3.6-27B-AEON-Ultimate-Uncensored-NVFP4
AEON_DFLASH_REPO=z-lab/Qwen3.6-27B-DFlash
AEON_MODEL_DIR=/home/YOUR_USER/LLMs/AEON-7/Qwen3.6-27B-AEON-Ultimate-Uncensored-NVFP4
AEON_DFLASH_DIR=/home/YOUR_USER/LLMs/z-lab/Qwen3.6-27B-DFlash
AEON_VLLM_PORT=8002
AEON_GPU_MEMORY_UTILIZATION=0.75
AEON_MAX_MODEL_LEN=256000
AEON_MAX_NUM_SEQS=64
AEON_MAX_NUM_BATCHED_TOKENS=16384

# LiteLLM keys and admin UI login. Change these before exposing the stack to a network.
LITELLM_MASTER_KEY=change-me
LITELLM_SALT_KEY=change-me-salt
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=change-me

# LiteLLM admin UI database. Required by recent LiteLLM UI login flows.
LITELLM_POSTGRES_DB=litellm
LITELLM_POSTGRES_USER=litellm
LITELLM_POSTGRES_PASSWORD=change-me-db-password

# Langfuse audit/observability callback. These values must match
# Docker/Langfuse/.env when the Langfuse stack is enabled.
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# Open WebUI persistent auth is enabled by default.
WEBUI_SECRET_KEY=change-me-webui-secret
