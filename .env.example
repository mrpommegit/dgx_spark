# Local model/runtime paths
LLM_ROOT_PATH=/path/to/local/llm/root

# Docker configuration
DOCKER_NETWORK=dgx-spark
REGISTRY=registry.example.com
IMAGE_NAMESPACE=dgx-spark

# ComfyUI image/video generation settings
COMFYUI_DATA_DIR=./comfyui/data
COMFYUI_PORT=8188
COMFYUI_REF=master
COMFYUI_IMAGE=dgx-spark-comfyui:local
COMFYUI_CONTAINER_NAME=comfyui
COMFYUI_SHM_SIZE=16gb
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu130
COMFYUI_ARGS=--listen 0.0.0.0 --port 8188 --enable-manager
COMFYUI_EXTRA_ARGS=
COMFYUI_CUSTOM_NODE_REPOS=https://github.com/ltdrdata/ComfyUI-Manager.git https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite.git

# GitHub access
GH_USER=your-github-username
GH_PAT=your-github-personal-access-token

# Hugging Face access
HF_TOKEN=your-hugging-face-token

# NetworkManager Wi-Fi helper settings
CONNECTION_NAME=your-networkmanager-connection-name
WIFI_INTERFACE=your-wifi-interface

# Tailscale connectivity settings
# Generate auth keys in the Tailscale admin console. Leave empty for interactive login.
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=dgx-spark
TAILSCALE_ACCEPT_ROUTES=false
TAILSCALE_SSH=false
TAILSCALE_ADVERTISE_EXIT_NODE=false
TAILSCALE_ADVERTISE_ROUTES=
TAILSCALE_ADVERTISE_TAGS=
TAILSCALE_EXTRA_ARGS=
